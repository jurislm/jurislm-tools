{
  "mcpServers": {
    "coolify": {
      "command": "npx",
      "args": ["-y", "@jurislm/coolify-mcp@latest"],
      "env": {
        "COOLIFY_ACCESS_TOKEN": "${COOLIFY_ACCESS_TOKEN}",
        "COOLIFY_BASE_URL": "${COOLIFY_BASE_URL}"
      }
    },
    "hetzner": {
      "command": "npx",
      "args": ["-y", "github:jurislm/hetzner-mcp#v1.0.0"],
      "env": {
        "HETZNER_API_TOKEN": "${HETZNER_API_TOKEN}"
      }
    }
  }
}
